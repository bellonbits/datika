# ─── Database (Aiven PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgres://avnadmin:YOUR_PASSWORD@pg-xxxx.e.aivencloud.com:14741/defaultdb?sslmode=require

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_256bit_random_string
JWT_REFRESH_SECRET=replace_with_different_256bit_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ─── Groq AI (llama-4-scout — multimodal, fast, free tier available) ─────────
GROQ_API_KEY=gsk_...
GROQ_MODEL_CONTENT=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_GRADING=meta-llama/llama-4-scout-17b-16e-instruct

# ─── MinIO (self-hosted S3-compatible object storage) ────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=datika-assets
MINIO_PUBLIC_URL=http://localhost:9000

# ─── Lipana (M-Pesa simplified API — https://lipana.dev) ─────────────────────
LIPANA_SECRET_KEY=lip_sk_live_...
LIPANA_WEBHOOK_SECRET=your_webhook_secret_from_lipana_dashboard
LIPANA_BASE_URL=https://api.lipana.dev/v1

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
