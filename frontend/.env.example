NEXT_PUBLIC_API_URL=https://datika-eight.vercel.app/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_APP_NAME=Datika
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# Auth secrets (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Supabase Storage (server-side only — never use NEXT_PUBLIC_)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# YouTube Data API v3 (console.cloud.google.com → Enable YouTube Data API v3)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Lipana (M-Pesa)
LIPANA_SECRET_KEY=your_lipana_secret_key
LIPANA_WEBHOOK_SECRET=https://yourdomain.com/api/v1/payments/webhook
LIPANA_BASE_URL=https://api.lipana.dev/v1
